<style>
  :root{
    --black:#0B0A08;--black-2:#121110;--line:#262220;
    --white:#F7F4EE;--dim:#A39C8F;--dim-2:#8C8576;
    --gold:#C8A24A;--gold-bright:#E7CB85;--gold-deep:#8E6F2E;
    --maxw:1160px;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{font-size:18px;scroll-behavior:smooth}
  body{background:var(--black);color:var(--white);font-family:"Hanken Grotesk",system-ui,sans-serif;font-weight:400;line-height:1.65;-webkit-font-smoothing:antialiased;overflow-x:hidden}
  a{color:inherit;text-decoration:none}
  .wrap{max-width:var(--maxw);margin:0 auto;padding:0 30px}
  .eyebrow{display:inline-block;font-size:.82rem;font-weight:500;letter-spacing:.3em;text-transform:uppercase;color:var(--gold)}
  .display{font-family:"Fraunces",serif;font-optical-sizing:auto;font-weight:400;letter-spacing:-.015em;line-height:1.05}
  .it{font-family:"Fraunces",serif;font-style:italic;font-weight:400}
  .gold-text{background:linear-gradient(100deg,var(--gold-bright),var(--gold) 45%,var(--gold-deep));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
  .cn{display:inline-block;vertical-align:middle}
  @keyframes breathe{0%,100%{opacity:.6;transform:scale(1)}50%{opacity:1;transform:scale(1.06)}}
  @keyframes spin{to{transform:rotate(360deg)}}

  /* nav */
  header.nav{position:sticky;top:0;z-index:60;backdrop-filter:blur(16px);background:rgba(11,10,8,.74);border-bottom:1px solid transparent;transition:border-color .4s}
  header.nav.scrolled{border-bottom:1px solid var(--line)}
  .nav-inner{display:flex;align-items:center;justify-content:space-between;height:78px}
  .brandmark{display:flex;align-items:center;gap:13px;font-family:"Fraunces",serif;font-size:1.16rem;letter-spacing:.06em;text-transform:uppercase}
  .brandmark .cn{width:34px;height:28px}
  .navlinks{display:flex;align-items:center;gap:34px}
  .navlinks a{font-size:.9rem;letter-spacing:.04em;color:var(--dim);transition:color .25s}
  .navlinks a:hover{color:var(--white)}
  .nav-cta{border:1px solid var(--line);padding:10px 18px;border-radius:999px;color:var(--white);font-size:.88rem;letter-spacing:.04em;transition:border-color .3s,color .3s}
  .nav-cta:hover{border-color:var(--gold);color:var(--gold)}
  .navtoggle{display:none;background:none;border:0;color:var(--white);font-size:1.6rem;cursor:pointer}

  /* hero */
  .hero{position:relative;padding:120px 0 100px;overflow:hidden}
  .gold-glow{position:absolute;top:-280px;left:50%;transform:translateX(-50%);width:1100px;height:1000px;border-radius:50%;background:radial-gradient(closest-side,rgba(200,162,74,.18),rgba(142,111,46,.07) 42%,transparent 70%);filter:blur(6px);pointer-events:none;animation:breathe 10s ease-in-out infinite}
  .hero-watermark{position:absolute;top:40px;left:50%;transform:translateX(-50%);width:520px;height:428px;opacity:.05;pointer-events:none}
  .hero-rays{position:absolute;top:-360px;left:50%;width:820px;height:820px;transform:translateX(-50%);pointer-events:none;opacity:.3;animation:spin 150s linear infinite}
  .hero-inner{position:relative;z-index:2;max-width:900px}
  .hero .cn-hero{width:74px;height:61px;margin-bottom:30px;animation:breathe 7s ease-in-out infinite}
  .hero h1{font-size:clamp(2.6rem,6.4vw,5rem);margin:22px 0 28px}
  .hero .lede{font-size:1.16rem;color:var(--dim);max-width:640px}
  .hero .lede strong{color:var(--white);font-weight:500}

  /* doors */
  .doors{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:58px;position:relative;z-index:2}
  .door{position:relative;border:1px solid var(--line);border-radius:16px;padding:36px 32px 30px;background:var(--black-2);overflow:hidden;transition:transform .45s cubic-bezier(.2,.7,.2,1),border-color .45s,box-shadow .45s}
  .door::after{content:"";position:absolute;inset:0;opacity:0;transition:opacity .5s;background:radial-gradient(120% 90% at 0% 0%,rgba(200,162,74,.12),transparent 55%)}
  .door:hover{transform:translateY(-7px);border-color:rgba(200,162,74,.55);box-shadow:0 30px 70px -34px rgba(0,0,0,.8)}
  .door:hover::after{opacity:1}
  .door .chap{font-size:.82rem;letter-spacing:.24em;text-transform:uppercase;color:var(--gold);font-weight:500}
  .door h3{font-family:"Fraunces",serif;font-weight:400;font-size:1.74rem;margin:15px 0 10px}
  .door p{color:var(--dim);font-size:.97rem;position:relative;z-index:2}
  .door .go{display:inline-flex;align-items:center;gap:9px;margin-top:22px;color:var(--gold);font-size:.88rem;letter-spacing:.08em;text-transform:uppercase;position:relative;z-index:2}
  .door .go .arr{transition:transform .3s}
  .door:hover .go .arr{transform:translateX(6px)}

  /* sections */
  .sec{padding:108px 0;border-top:1px solid var(--line);position:relative}
  .sec-head{max-width:680px}
  .sec-head h2{font-size:clamp(2rem,4.6vw,3.2rem);margin:15px 0 16px}
  .sec-head .sub{color:var(--dim);font-size:1.08rem}
  .sec-head .sub .it{color:var(--white)}
  .chapmark{font-size:.82rem;letter-spacing:.26em;text-transform:uppercase;color:var(--gold);font-weight:500}

  /* "we listened" trio */
  .trio{display:flex;flex-wrap:wrap;gap:14px 40px;align-items:baseline;margin:42px 0 8px;padding-bottom:30px;border-bottom:1px solid var(--line)}
  .trio .want{font-family:"Fraunces",serif;font-style:italic;font-size:1.18rem;color:var(--white)}
  .trio .sep{color:var(--gold);font-size:1.1rem}
  .trio .stamp{margin-left:auto;font-size:.82rem;letter-spacing:.24em;text-transform:uppercase;color:var(--dim-2)}

  /* movement band */
  .band-label{display:flex;align-items:center;gap:16px;margin:46px 0 24px}
  .band-label .k{font-size:.84rem;letter-spacing:.26em;text-transform:uppercase;color:var(--gold);font-weight:500}
  .band-label .ln{flex:1;height:1px;background:linear-gradient(90deg,rgba(200,162,74,.4),transparent)}

  .svc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
  .svc-grid.two{grid-template-columns:repeat(3,1fr)}
  .card{border:1px solid var(--line);border-radius:14px;padding:26px 24px;background:var(--black-2);transition:transform .4s,border-color .4s}
  .card:hover{transform:translateY(-5px);border-color:rgba(200,162,74,.42)}
  .card .rn{font-family:"Fraunces",serif;font-style:italic;font-size:.95rem;color:var(--gold)}
  .card h4{font-family:"Fraunces",serif;font-weight:500;font-size:1.22rem;margin:10px 0 8px;letter-spacing:-.01em}
  .card p{color:var(--dim);font-size:.92rem}

  /* process strip */
  .process{display:grid;grid-template-columns:repeat(5,1fr);margin-top:42px;border:1px solid var(--line);border-radius:14px;overflow:hidden}
  .process .step{padding:22px 18px;border-right:1px solid var(--line)}
  .process .step:last-child{border-right:0}
  .process .step .n{font-family:"Fraunces",serif;font-style:italic;color:var(--gold);font-size:.95rem}
  .process .step .t{font-family:"Fraunces",serif;font-size:1.12rem;margin:5px 0 4px}
  .process .step .d{font-size:.88rem;color:var(--dim)}

  .who{display:flex;flex-wrap:wrap;gap:9px;margin-top:34px}
  .who .lbl{font-size:.82rem;letter-spacing:.2em;text-transform:uppercase;color:var(--dim-2);align-self:center;margin-right:6px}
  .pill{border:1px solid var(--line);border-radius:999px;padding:7px 15px;font-size:.88rem;color:var(--dim)}

  /* human tracks */
  .cred{display:inline-flex;align-items:center;gap:11px;margin-top:30px;border:1px solid rgba(200,162,74,.45);border-radius:999px;padding:10px 20px;font-size:.86rem;letter-spacing:.05em;color:var(--gold);background:rgba(200,162,74,.06)}

  /* about */
  .about-lead{max-width:760px;font-family:"Fraunces",serif;font-weight:300;font-size:clamp(1.3rem,2.6vw,1.7rem);line-height:1.45;letter-spacing:-.01em;margin-top:8px}
  .about-lead .it{color:var(--gold-bright)}
  .mv{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:48px}
  .mv-block{border:1px solid var(--line);border-radius:16px;padding:36px 32px;background:var(--black-2)}
  .mv-block .k{font-size:.82rem;letter-spacing:.26em;text-transform:uppercase;color:var(--gold);font-weight:500}
  .mv-block .v{font-family:"Fraunces",serif;font-weight:300;font-size:1.42rem;line-height:1.38;margin-top:14px;letter-spacing:-.01em}
  .mv-block .v .it{font-style:italic;color:var(--gold-bright)}
  .values{margin-top:26px}
  .vrow{display:grid;grid-template-columns:48px 1.1fr 2fr;gap:22px;align-items:baseline;padding:24px 0;border-top:1px solid var(--line)}
  .vrow .num{font-family:"Fraunces",serif;font-style:italic;color:var(--gold);font-size:1.05rem}
  .vrow .vt{font-family:"Fraunces",serif;font-size:1.26rem}
  .vrow .vd{color:var(--dim);font-size:.96rem}

  /* contact */
  .cta{padding:112px 0;border-top:1px solid var(--line);position:relative;overflow:hidden;text-align:center}
  .cta .g{position:absolute;bottom:-440px;left:50%;transform:translateX(-50%);width:900px;height:900px;border-radius:50%;background:radial-gradient(closest-side,rgba(200,162,74,.15),transparent 68%);pointer-events:none}
  .cta-inner{position:relative;z-index:2;max-width:660px;margin:0 auto}
  .cta .cn-cta{width:60px;height:49px;margin-bottom:22px}
  .cta h2{font-size:clamp(2rem,4.8vw,3.3rem);margin:6px 0 16px}
  .cta p{color:var(--dim);font-size:1.06rem;margin-bottom:30px}
  .btn{display:inline-flex;align-items:center;gap:10px;cursor:pointer;border:0;font-size:.9rem;letter-spacing:.06em;text-transform:uppercase;padding:16px 30px;border-radius:999px;color:var(--black);font-weight:600;background:linear-gradient(100deg,var(--gold-bright),var(--gold) 50%,var(--gold-deep));transition:transform .3s,box-shadow .3s}
  .btn:hover{transform:translateY(-3px);box-shadow:0 20px 46px -18px rgba(200,162,74,.55)}
  .contact-meta{margin-top:34px;display:flex;flex-wrap:wrap;justify-content:center;gap:10px 26px;color:var(--dim);font-size:.9rem}
  .contact-meta a{color:var(--white)}
  .contact-meta .mt{color:var(--dim-2)}

  /* footer */
  footer{border-top:1px solid var(--line);padding:56px 0 40px}
  .foot{display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:32px}
  .foot .b{font-family:"Fraunces",serif;font-size:1.2rem;letter-spacing:.06em;text-transform:uppercase;display:flex;align-items:center;gap:13px}
  .foot .b .cn{width:30px;height:25px}
  .foot .tagline{color:var(--dim-2);font-size:.92rem;margin-top:13px;max-width:300px}
  .foot-col h5{font-size:.82rem;letter-spacing:.2em;text-transform:uppercase;color:var(--dim-2);margin-bottom:14px;font-weight:500}
  .foot-col a{display:block;color:var(--dim);font-size:.9rem;margin-bottom:9px;transition:color .25s}
  .foot-col a:hover{color:var(--gold)}
  .foot-bottom{margin-top:46px;padding-top:22px;border-top:1px solid var(--line);display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;color:var(--dim-2);font-size:.85rem;letter-spacing:.06em;text-transform:uppercase}

  .reveal{opacity:0;transform:translateY(26px);transition:opacity .85s ease,transform .85s cubic-bezier(.2,.7,.2,1)}
  .reveal.in{opacity:1;transform:none}

  @media(max-width:880px){
    .navlinks{display:none}.navtoggle{display:block}
    .doors{grid-template-columns:1fr}
    .svc-grid,.svc-grid.two{grid-template-columns:1fr}
    .process{grid-template-columns:1fr;}
    .process .step{border-right:0;border-bottom:1px solid var(--line)}
    .process .step:last-child{border-bottom:0}
    .mv{grid-template-columns:1fr}
    .vrow{grid-template-columns:36px 1fr;gap:12px}
    .vrow .vd{grid-column:1/-1}
    .trio .stamp{margin-left:0;width:100%}
    .hero{padding:84px 0 74px}
  }
  @media(prefers-reduced-motion:reduce){*{animation:none!important;scroll-behavior:auto}.reveal{opacity:1;transform:none;transition:none}}
  :focus-visible{outline:2px solid var(--gold);outline-offset:3px;border-radius:4px}

  .langswitch{background:none;border:1px solid var(--line);color:var(--dim);border-radius:999px;padding:7px 15px;font-size:.82rem;letter-spacing:.1em;cursor:pointer;transition:border-color .3s,color .3s;font-family:"Hanken Grotesk",sans-serif;margin-left:14px}
  .langswitch:hover{border-color:var(--gold);color:var(--gold)}
  @media(max-width:880px){.langswitch{margin-left:auto;margin-right:10px}}
</style>
