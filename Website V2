<style>
  /* --- additions for new content, in the same aesthetic --- */
  .prose-block{max-width:760px;color:var(--dim);font-size:1.06rem;margin-top:6px}
  .prose-block strong{color:var(--white);font-weight:500}
  .prompts{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-top:30px}
  .prompt{border:1px solid rgba(200,162,74,.3);border-left:3px solid var(--gold);border-radius:14px;padding:28px 30px;background:rgba(200,162,74,.045);font-family:"Fraunces",serif;font-style:italic;font-size:1.22rem;line-height:1.4;color:var(--white)}
  .prompt .q{color:var(--gold);font-style:normal}
  .resolve{margin-top:26px;font-size:1.06rem;color:var(--dim);max-width:780px}
  .resolve strong{color:var(--white);font-weight:500}
  /* track record */
  .stat-big{font-family:"Fraunces",serif;font-weight:300;font-size:clamp(1.7rem,3.8vw,2.7rem);line-height:1.3;letter-spacing:-.01em;margin:10px 0 4px;max-width:880px}
  .stat-big .it{color:var(--gold-bright)}
  .track{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:44px}
  .track-col{border:1px solid var(--line);border-radius:16px;padding:34px 32px;background:var(--black-2)}
  .track-col .k{font-size:.82rem;letter-spacing:.26em;text-transform:uppercase;color:var(--gold);font-weight:500;margin-bottom:20px;display:block}
  .track-col .pins{display:flex;flex-wrap:wrap;gap:9px}
  .track-col .pin{display:inline-flex;align-items:center;gap:8px}
  .track-col .pin svg{color:var(--gold);flex:none}
  /* two-column CTA */
  .cta-cols{display:grid;grid-template-columns:1fr 1fr;border:1px solid var(--line);border-radius:18px;overflow:hidden;margin-top:40px;text-align:center}
  .cta-col{padding:50px 42px;display:flex;flex-direction:column;align-items:center;transition:background .4s}
  .cta-col:first-child{border-right:1px solid var(--line)}
  .cta-col:hover{background:rgba(200,162,74,.05)}
  .cta-col h3{font-family:"Fraunces",serif;font-weight:400;font-size:1.72rem;margin-bottom:12px}
  .cta-col p{color:var(--dim);font-size:.98rem;margin-bottom:30px;max-width:300px}
  .cta-col .btn{margin-top:auto}
  /* world map */
  .worldmap{margin-top:40px;border:1px solid var(--line);border-radius:16px;background:var(--black-2);padding:24px 22px}
  .worldmap .legend{display:flex;gap:26px;margin-bottom:10px;flex-wrap:wrap}
  .worldmap .lg{display:inline-flex;align-items:center;gap:9px;font-size:.86rem;letter-spacing:.06em;text-transform:uppercase;color:var(--dim)}
  .worldmap .lg .dot{width:11px;height:11px;border-radius:50%}
  .worldmap .lg .dot.c{background:var(--gold);box-shadow:0 0 0 3px rgba(200,162,74,.22)}
  .worldmap .lg .dot.t{background:var(--white);box-shadow:0 0 0 3px rgba(247,244,238,.16)}
  .worldmap .map{width:100%;height:auto;display:block}
  .worldmap .land{fill:#1b1916;stroke:var(--line);stroke-width:.6;stroke-linejoin:round}
  .pin-c{fill:var(--gold)} .pin-t{fill:var(--white)}
  .pin-halo-c{fill:var(--gold);opacity:.16} .pin-halo-t{fill:var(--white);opacity:.13}
  .map-lbl{font-family:"Hanken Grotesk",sans-serif;font-size:14px;fill:var(--white);opacity:.78;letter-spacing:.02em}
  @media(max-width:880px){
    .prompts{grid-template-columns:1fr}
    .track{grid-template-columns:1fr}
    .cta-cols{grid-template-columns:1fr}
    .cta-col:first-child{border-right:0;border-bottom:1px solid var(--line)}
  }

  /* --- improvements --- */
  .skip{position:absolute;left:-9999px;top:0;background:var(--gold);color:#000;padding:11px 18px;z-index:999;border-radius:0 0 6px 0;font-size:.85rem;letter-spacing:.06em}
  .skip:focus{left:0}
  .hero-desc{color:var(--dim);font-size:1.02rem;max-width:560px;margin-top:18px}
  .about-grid{display:grid;grid-template-columns:.7fr 1.3fr;gap:50px;align-items:center;margin-top:8px}
  .about-portrait{aspect-ratio:1/1;border:1px solid var(--line);border-radius:18px;background:radial-gradient(circle at 50% 38%,rgba(200,162,74,.14),transparent 62%),var(--black-2);display:flex;align-items:center;justify-content:center}
  .about-portrait .cn{width:130px;height:107px;opacity:.82}
  .about-lead{font-family:"Fraunces",serif;font-weight:300;font-size:clamp(1.3rem,2.6vw,1.7rem);line-height:1.4;letter-spacing:-.01em;color:var(--white)}
  .about-body .prose-block{margin-top:18px}
  .map-list{display:none;margin-top:24px;gap:26px}
  .map-list .k{font-size:.82rem;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);margin-bottom:8px;display:block}
  .map-list p{color:var(--dim);font-size:.98rem}
  @media(max-width:880px){
    #nav .navlinks{position:fixed!important;inset:0;display:flex!important;flex-direction:column;align-items:center;justify-content:center;gap:34px;background:rgba(11,10,8,.97);-webkit-backdrop-filter:blur(14px);backdrop-filter:blur(14px);transform:translateX(100%);transition:transform .4s;z-index:90}
    #nav.menu-open .navlinks{transform:none}
    .navtoggle{display:block;position:relative;z-index:95;font-size:1.7rem;line-height:1}
    .about-grid{grid-template-columns:1fr;gap:30px}
    .about-portrait{max-width:230px;margin:0 auto;width:100%}
  }
  @media(max-width:760px){ .map-list{display:grid;grid-template-columns:1fr 1fr} }
  @media(max-width:520px){ .map-list{grid-template-columns:1fr} }
</style>

