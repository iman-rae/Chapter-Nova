<script>
(function(){
  function apply(l){
    document.documentElement.lang=l;
    document.querySelectorAll('[data-fr]').forEach(function(el){
      var v = l==='fr' ? el.getAttribute('data-fr') : el.getAttribute('data-en');
      if(v===null) return;
      if(v.indexOf('<')>=0) el.innerHTML=v; else el.textContent=v;
    });
    document.querySelectorAll('.langswitch').forEach(function(b){ b.textContent = l==='fr' ? 'EN' : 'FR'; });
    try{ localStorage.setItem('cn_lang', l); }catch(e){}
  }
  window.toggleLang=function(){
    var cur = document.documentElement.lang==='fr' ? 'fr':'en';
    apply(cur==='fr' ? 'en':'fr');
  };
  var init=null;
  try{ init = localStorage.getItem('cn_lang'); }catch(e){}
  if(!init){ init = (navigator.language||'').toLowerCase().indexOf('fr')===0 ? 'fr' : 'en'; }
  apply(init);
})();
</script><script>
(function(){
  var nav=document.getElementById('nav'), tog=document.getElementById('navtoggle');
  if(tog){
    tog.addEventListener('click',function(){
      var open=nav.classList.toggle('menu-open');
      tog.setAttribute('aria-expanded',open?'true':'false');
      tog.innerHTML=open?'\u2715':'\u2261';
    });
    document.querySelectorAll('#navlinks a').forEach(function(a){
      a.addEventListener('click',function(){nav.classList.remove('menu-open');tog.setAttribute('aria-expanded','false');tog.innerHTML='\u2261';});
    });
  }
})();
</script></body></html>
